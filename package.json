{
  "name": "@superdispatch/sdk",
  "version": "0.10.0",
  "private": false,
  "description": "Super Dispatch JavaScript SDK",
  "repository": "git@github.com:superdispatch/sdk.git",
  "license": "MIT",
  "author": "Umidbek Karimov <uma.karimov@gmail.com>",
  "main": "src/index.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pika build && node scripts/fix-package-json.js",
    "prerelease": "pnpm install --force && pnpm run lint && pnpm run tsc && pnpm run build",
    "release": "npm publish ./pkg",
    "lint": "js-tools lint",
    "tsc": "tsc",
    "tdd": "jest --watch",
    "test": "jest --coverage",
    "version": "pnpm run build"
  },
  "lint-staged": {
    "*": [
      "js-tools lint --fix --quiet"
    ]
  },
  "prettier": "@superdispatch/prettier-config",
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.spec.ts"
    ],
    "testPathIgnorePatterns": [
      "/pkg/",
      "/node_modules/"
    ]
  },
  "devDependencies": {
    "@pika/cli": "0.2.0",
    "@pika/pack": "0.5.0",
    "@pika/plugin-build-node": "0.9.2",
    "@pika/plugin-build-types": "0.9.2",
    "@pika/plugin-build-web": "0.9.2",
    "@pika/plugin-bundle-types": "0.9.2",
    "@pika/plugin-standard-pkg": "0.9.2",
    "@superdispatch/babel-preset": "0.14.0",
    "@superdispatch/eslint-plugin": "0.14.0",
    "@superdispatch/js-tools": "0.14.0",
    "@superdispatch/prettier-config": "0.14.0",
    "@superdispatch/tsconfig": "0.14.0",
    "@types/jest": "28.1.8",
    "eslint": "8.57.1",
    "husky": "9.1.7",
    "jest": "28.1.3",
    "lint-staged": "15.5.2",
    "prettier": "2.7.1",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "@pika/pack": {
    "pipeline": [
      [
        "@pika/plugin-standard-pkg",
        {
          "exclude": [
            "__tests__/**/*",
            "__testutils__/**/*"
          ]
        }
      ],
      [
        "@pika/plugin-build-node"
      ],
      [
        "@pika/plugin-build-web"
      ],
      [
        "@pika/plugin-build-types",
        {
          "tsconfig": "./tsconfig.build.json"
        }
      ],
      [
        "@pika/plugin-bundle-types"
      ]
    ]
  }
}
